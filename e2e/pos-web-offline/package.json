{
	"name": "@x-test/pos-web-offline",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"description": "E2E test project for the web version of POS BLUE OFFLINE",
	"scripts": {
		"clean": "rimraf dist .turbo tsconfig.tsbuildinfo test-artifacts playwright-report allure-results allure-report",
		"typecheck": "tsc --noEmit",
		"bdd:watch": "nodemon -w src -e ts,feature --exec \"pnpm bddgen\"",
		"report": "playwright show-report playwright-report",
		"report:allure": "allure open allure-report",
		"pretest": "bddgen",
		"bddgen": "pnpm exec bddgen --tags \"not @skip\"",
		"test": "playwright test",
		"test:ui": "pnpm run pretest && pnpm exec playwright test --ui",
		"test:debug": "pnpm test --debug"
	},
	"devDependencies": {
		"@dotenvx/dotenvx": "^1.60.0",
		"@playwright/test": "^1.59.1",
		"@types/fs-extra": "^11.0.4",
		"@types/node": "^24.12.2",
		"@x-test/common": "workspace:*",
		"allure-commandline": "^2.38.1",
		"allure-playwright": "^3.6.0",
		"fs-extra": "^11.3.4",
		"nodemon": "^3.1.14",
		"playwright-bdd": "^8.5.0",
		"remeda": "^2.33.7",
		"rimraf": "^6.1.3",
		"typescript": "^6.0.2",
		"zod": "^4.3.6"
	}
}
